-- // LOGIC AUTO FARM PLAYER (FIXED) // --
local function GetClosestTarget()
    local target, dist = nil, math.huge
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
            local d = (p.Character.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
            if d < dist then dist = d target = p end
        end
    end
    return target
end

RunService.Heartbeat:Connect(function()
    if Settings.AutoWinBeta then
        local target = GetClosestTarget()
        if target and target.Character and LocalPlayer.Character then
            local myHrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            local tHrp = target.Character:FindFirstChild("HumanoidRootPart")
            
            if myHrp and tHrp then
                -- FIX: Dùng CFrame Lerp mượt hơn + Reset Velocity để không bị văng
                myHrp.Velocity = Vector3.new(0, 0, 0)
                myHrp.CFrame = myHrp.CFrame:Lerp(tHrp.CFrame * CFrame.new(0, Settings.UnderDepth, 0) * CFrame.Angles(math.rad(90), 0, 0), 0.6)
                
                -- Auto Attack
                game:GetService("VirtualUser"):Button1Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
                if Settings.AutoSkill then
                    for i = 1, 4 do VIM:SendKeyEvent(true, tostring(i), false, game) end
                end
            end
        end
    end
end)

-- // HỆ THỐNG ESP ĐA NĂNG // --
local function CreateESP(player)
    local Box = Drawing.new("Square")
    local Tracer = Drawing.new("Line")
    local Name = Drawing.new("Text")
    
    RunService.RenderStepped:Connect(function()
        if Settings.ESP_Enabled and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character.Humanoid.Health > 0 then
            local hrp = player.Character.HumanoidRootPart
            local pos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(hrp.Position)
            
            if onScreen then
                -- Box ESP
                if Settings.ESP_Box then
                    Box.Visible = true
                    Box.Size = Vector2.new(2000 / pos.Z, 2500 / pos.Z)
                    Box.Position = Vector2.new(pos.X - Box.Size.X / 2, pos.Y - Box.Size.Y / 2)
                    Box.Color = Color3.fromRGB(255, 0, 0)
                    Box.Thickness = 1
                else Box.Visible = false end
                
                -- Tracer
                if Settings.ESP_Tracer then
                    Tracer.Visible = true
                    Tracer.From = Vector2.new(workspace.CurrentCamera.ViewportSize.X / 2, workspace.CurrentCamera.ViewportSize.Y)
                    Tracer.To = Vector2.new(pos.X, pos.Y)
                    Tracer.Color = Color3.fromRGB(255, 0, 0)
                else Tracer.Visible = false end
                
                -- Name & Dist
                if Settings.ESP_Names or Settings.ESP_Dist then
                    Name.Visible = true
                    local text = ""
                    if Settings.ESP_Names then text = text .. player.Name end
                    if Settings.ESP_Dist then text = text .. " [" .. math.floor((hrp.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude) .. "m]" end
                    Name.Text = text
                    Name.Position = Vector2.new(pos.X, pos.Y - Box.Size.Y / 2 - 15)
                    Name.Size = 14
                    Name.Center = true
                    Name.Outline = true
                    Name.Color = Color3.fromRGB(255, 255, 255)
                else Name.Visible = false end
            else
                Box.Visible = false Tracer.Visible = false Name.Visible = false
            end
        else
            Box.Visible = false Tracer.Visible = false Name.Visible = false
        end
    end)
end

for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer then CreateESP(p) end end
Players.PlayerAdded:Connect(CreateESP)

